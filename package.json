    "@mui/material": "^7.3.9",
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@vitejs/plugin-react-swc": "^3.3.2",
    "axios": "^1.7.7",
    "classnames": "^2.3.2",
    "dompurify": "^3.3.3",
    "elliptic": "^6.6.1",
    "esbuild": "^0.25.0",
    "eslint-config-react-app": "^7.0.1",
    "flatted": "^3.4.0",
    "immutable": "^5.1.5",
